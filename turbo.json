{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "DRAFT_LOG_WS_EVENTS",
    "DRAFT_MODE",
    "DRAFT_PORT",
    "DRAFT_NO_BROWSER",
    "DRAFT_STATE_DIR",
    "DRAFT_AUTH_TOKEN",
    "DRAFT_DESKTOP_WS_URL",
    "DRAFT_HOST",
    "DRAFT_AUTO_BOOTSTRAP_PROJECT_FROM_CWD"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@draft/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    }
  }
}
